{
  "name": "caelum",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:provenance": "python3 scripts/check_provenance.py",
    "attest": "node scripts/emit-us-origin-attestation.mjs dist/caelum",
    "size:lib": "node scripts/check-lib-size.mjs",
    "build:lib": "ng build caelum && npm run attest && npm run size:lib && npm run check:exports",
    "check:exports": "node scripts/check-lib-exports.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/aria": "^22.0.3",
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.3",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@tanstack/table-core": "8.21.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.39.4",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.0.8"
  }
}
